<!DOCTYPE html>
<html class="dark" lang="fr">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{{ title or "KC Catalogue" }}</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d46f2",
                        "dark-bg": "#151515",
                        "card-bg": "#202020",
                        "hover-bg": "#2a2a2a",
                        "text-main": "#ffffff",
                        "text-muted": "#757575",
                        "danger": "#ef4444",
                        "success": "#22c55e",
                        "warning": "#eab308",
                    },
                    fontFamily: { "display": ["Space Grotesk", "sans-serif"] },
                    screens: { "3xl": "1920px" },
                },
            },
        }
    </script>
    <style>
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #555; }

        .sidebar-link { position: relative; transition: all 0.15s ease; }
        .sidebar-link:hover { background: rgba(255,255,255,0.04); }
        .sidebar-link.active { color: #fff; font-weight: 700; background: rgba(13,70,242,0.1); }
        .sidebar-link.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 60%;
            background: #0d46f2;
            border-radius: 0 3px 3px 0;
        }
        .card-hover-effect { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .card-hover-effect:hover { transform: translateY(-4px); z-index: 10; box-shadow: 0 12px 40px rgba(0,0,0,0.6); }
        .hero-gradient { background: linear-gradient(0deg, #151515 0%, rgba(21,21,21,0.8) 50%, rgba(21,21,21,0.4) 100%); }
        .profile-banner-gradient { background: linear-gradient(180deg, rgba(21,21,21,0) 0%, #151515 100%); }
        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .score-badge { min-width: 2.5rem; text-align: center; }

        /* Sidebar section spacing */
        .sidebar-section { padding-bottom: 0.75rem; margin-bottom: 0.25rem; }

        /* Platform pill hover */
        .platform-pill { transition: all 0.15s ease; }
        .platform-pill:hover { background: rgba(13,70,242,0.15); border-color: rgba(13,70,242,0.4); color: #fff; }
    </style>
    {% block head %}{% endblock %}
</head>

<body class="bg-dark-bg text-text-main font-display antialiased selection:bg-primary selection:text-white">

    <!-- HEADER -->
    <header class="fixed top-0 left-0 w-full z-50 bg-dark-bg/95 backdrop-blur-md h-[72px] flex items-center px-4 lg:px-8 gap-6 border-b border-white/[0.03]">
        <a href="/" class="text-2xl font-black tracking-wider uppercase whitespace-nowrap">
            KC <span class="text-primary">CATALOGUE</span>
        </a>

        <!-- Search Input -->
        <div class="flex-1 max-w-2xl relative hidden md:block group">
            <form action="/search" method="GET" class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <span class="material-icons text-text-muted text-lg group-focus-within:text-white transition-colors">search</span>
                </div>
                <input type="text" name="q" value="{{ searchQuery or '' }}"
                    class="w-full bg-white/[0.04] text-white rounded-xl py-2.5 pl-11 pr-4 border border-white/[0.06] hover:bg-white/[0.07] focus:bg-white focus:text-black focus:ring-0 focus:border-transparent transition-all placeholder:text-text-muted text-sm font-medium"
                    placeholder="Search {{ '50,000+' }} games...">
            </form>
        </div>

        <!-- User / Actions -->
        <div class="flex items-center gap-3 ml-auto">
            <button class="md:hidden p-2 text-white hover:bg-white/10 rounded-full" onclick="toggleMobileSearch()">
                <span class="material-icons">search</span>
            </button>

            {% if user %}
                {% if user.role == 'admin' %}
                    <a href="/admin" class="bg-red-500/10 text-red-400 px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-widest border border-red-500/20 hidden sm:flex items-center gap-1">
                        <span class="material-icons text-xs">shield</span> Admin
                    </a>
                {% endif %}

                <div class="relative group">
                    <button onclick="toggleUserDropdown()"
                        class="flex items-center gap-2.5 hover:opacity-80 transition-opacity focus:outline-none">
                        <div class="hidden sm:block text-right">
                            <div class="text-sm font-bold leading-tight">{{ user.username }}</div>
                        </div>
                        <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-primary to-violet-600 flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-primary/20 overflow-hidden">
                            {% if user.avatar_url %}
                                <img src="{{ user.avatar_url }}" alt="{{ user.username }}" class="w-full h-full object-cover">
                            {% else %}
                                {{ user.username[0] | upper }}
                            {% endif %}
                        </div>
                    </button>
                    <div id="user-dropdown"
                        class="absolute right-0 top-full mt-2 w-52 bg-card-bg rounded-xl shadow-2xl border border-white/5 hidden flex-col overflow-hidden z-[60]">
                        <div class="px-4 py-3 border-b border-white/5">
                            <div class="text-sm font-bold text-white">{{ user.username }}</div>
                            <div class="text-xs text-text-muted">{{ user.email }}</div>
                        </div>
                        <a href="/profile/{{ user.id }}" class="px-4 py-2.5 text-sm text-white hover:bg-white/5 flex items-center gap-2.5"><span class="material-icons text-base text-text-muted">person</span> My Profile</a>
                        <a href="/profile/{{ user.id }}/collection" class="px-4 py-2.5 text-sm text-white hover:bg-white/5 flex items-center gap-2.5"><span class="material-icons text-base text-text-muted">inventory_2</span> My Collection</a>
                        <a href="/profile/{{ user.id }}/wishlist" class="px-4 py-2.5 text-sm text-white hover:bg-white/5 flex items-center gap-2.5"><span class="material-icons text-base text-text-muted">star</span> My Wishlist</a>
                        <a href="/profile" class="px-4 py-2.5 text-sm text-white hover:bg-white/5 flex items-center gap-2.5"><span class="material-icons text-base text-text-muted">settings</span> Settings</a>
                        <div class="border-t border-white/5"></div>
                        <a href="/logout" class="px-4 py-2.5 text-sm text-red-400 hover:bg-red-500/5 flex items-center gap-2.5"><span class="material-icons text-base">logout</span> Log out</a>
                    </div>
                </div>
            {% else %}
                <a href="/login" class="flex items-center gap-2 bg-primary hover:bg-primary/80 text-white px-4 py-2 rounded-xl font-bold transition-colors text-sm shadow-lg shadow-primary/20">
                    <span class="material-icons text-sm">login</span> Sign in
                </a>
            {% endif %}

            <button class="lg:hidden p-2 text-white"
                onclick="document.getElementById('mobile-sidebar').classList.remove('-translate-x-full'); document.getElementById('sidebar-overlay').classList.remove('hidden')">
                <span class="material-icons">menu</span>
            </button>
        </div>
    </header>

    <!-- Mobile Search Bar -->
    <div id="mobile-search-bar" class="fixed top-[72px] left-0 w-full bg-dark-bg z-40 border-b border-white/[0.05] p-4 hidden md:hidden">
        <form action="/search" method="GET" class="relative">
            <input type="text" name="q" class="w-full bg-white/[0.04] text-white rounded-xl py-3 pl-11 pr-4 border border-white/[0.06] focus:bg-white/[0.08] focus:border-white/10 transition-all outline-none" placeholder="Search games...">
            <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-text-muted">search</span>
        </form>
    </div>

    <!-- WRAPPER -->
    <div class="pt-[72px] min-h-screen">

        <!-- SIDEBAR (Desktop) -->
        <aside class="hidden lg:flex flex-col w-[240px] flex-shrink-0 fixed h-[calc(100vh-72px)] overflow-y-auto pb-6 pt-5 bg-dark-bg">
            <nav class="px-3 space-y-0">



                <!-- New Releases -->
                <div class="sidebar-section">
                    <h3 class="text-[10px] font-bold text-text-muted px-3 mb-1.5 uppercase tracking-[0.15em]">New Releases</h3>
                    <a href="/?tab=last-month"
                        class="sidebar-link {% if tab == 'last-month' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-green-500/20 to-emerald-600/20 flex items-center justify-center text-green-400"><span class="material-icons text-sm">schedule</span></span>
                        Last 30 days
                    </a>
                    <a href="/?tab=this-year"
                        class="sidebar-link {% if tab == 'this-year' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-blue-500/20 to-cyan-600/20 flex items-center justify-center text-blue-400"><span class="material-icons text-sm">event</span></span>
                        This year
                    </a>
                    <a href="/calendar"
                        class="sidebar-link {% if tab == 'calendar' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-purple-500/20 to-fuchsia-600/20 flex items-center justify-center text-purple-400"><span class="material-icons text-sm">calendar_month</span></span>
                        Release Calendar
                    </a>
                </div>

                <!-- Top -->
                <div class="sidebar-section">
                    <h3 class="text-[10px] font-bold text-text-muted px-3 mb-1.5 uppercase tracking-[0.15em]">Top</h3>
                    <a href="/?tab=best-of-year"
                        class="sidebar-link {% if tab == 'best-of-year' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-yellow-500/20 to-amber-600/20 flex items-center justify-center text-yellow-400"><span class="material-icons text-sm">emoji_events</span></span>
                        Best of the year
                    </a>
                    <a href="/?tab=popular-2025"
                        class="sidebar-link {% if tab == 'popular-2025' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-purple-500/20 to-violet-600/20 flex items-center justify-center text-purple-400"><span class="material-icons text-sm">whatshot</span></span>
                        Popular in 2025
                    </a>
                    <a href="/?tab=top-250"
                        class="sidebar-link {% if tab == 'top-250' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center text-orange-400"><span class="material-icons text-sm">military_tech</span></span>
                        All time top 250
                    </a>
                    <a href="/?tab=popular"
                        class="sidebar-link {% if tab == 'popular' %}active{% endif %} flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-pink-500/20 to-rose-600/20 flex items-center justify-center text-pink-400"><span class="material-icons text-sm">trending_up</span></span>
                        Most Popular
                    </a>
                </div>

                <!-- Play -->
                <div class="sidebar-section">
                    <h3 class="text-[10px] font-bold text-text-muted px-3 mb-1.5 uppercase tracking-[0.15em]">Play</h3>
                    <a href="/higher-lower"
                        class="sidebar-link flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-indigo-500/20 to-blue-600/20 flex items-center justify-center text-indigo-400"><span class="material-icons text-sm">videogame_asset</span></span>
                        Higher or Lower ?
                    </a>
                    <a href="/quizz"
                        class="sidebar-link flex items-center gap-3 px-3 py-1.5 text-sm rounded-lg text-slate-400">
                        <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-amber-500/20 to-orange-600/20 flex items-center justify-center text-amber-400"><span class="material-icons text-sm">psychology</span></span>
                        Guess the Game
                    </a>
                </div>

                <!-- Platforms -->
                <div class="sidebar-section">
                    <h3 class="text-[10px] font-bold text-text-muted px-3 mb-2 uppercase tracking-[0.15em]">Platforms</h3>
                    <div class="flex flex-wrap gap-1.5 px-2">
                        {% if platforms %}
                            {% for p in platforms %}
                                {% set pUrl = "/?platforms=" ~ toggleFilter(activePlatforms, p.id) %}
                                {% if activeGenres and activeGenres.length > 0 %}{% set pUrl = pUrl ~ "&genres=" ~ activeGenres|join(',') %}{% endif %}
                                <a href="{{ pUrl }}" title="{{ p.name }}"
                                    class="platform-pill flex items-center gap-1.5 px-2.5 py-1 rounded-lg border {% if activePlatforms and p.id in activePlatforms %}bg-primary/20 border-primary/50 text-white{% else %}border-white/[0.06] bg-white/[0.02] text-slate-500{% endif %} text-xs font-medium">
                                    <span class="material-icons text-xs">{{ p.icon }}</span>
                                    <span>{{ p.name }}</span>
                                </a>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

                <!-- Genres -->
                <div class="sidebar-section">
                    <h3 class="text-[10px] font-bold text-text-muted px-3 mb-1.5 uppercase tracking-[0.15em]">Genres</h3>
                    <div class="px-3 mb-2">
                        <div class="relative group">
                            <input type="text" id="genre-search-desktop" placeholder="Filter genres..." 
                                class="w-full bg-white/[0.04] text-white border border-white/10 rounded-lg px-3 py-1.5 text-xs focus:bg-white/10 focus:border-primary focus:ring-0 transition-all outline-none"
                                onkeyup="filterGenres(this.value, 'genre-list-desktop')">
                            <span class="material-icons text-xs text-text-muted absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none group-focus-within:text-white">search</span>
                        </div>
                    </div>
                    <div id="genre-list-desktop" class="space-y-px max-h-[280px] overflow-y-auto">
                        {% if genres and genres.length > 0 %}
                            {% for genre in genres %}
                                {% set gUrl = "/?genres=" ~ toggleFilter(activeGenres, genre.id) %}
                                {% if activePlatforms and activePlatforms.length > 0 %}{% set gUrl = gUrl ~ "&platforms=" ~ activePlatforms|join(',') %}{% endif %}
                                <a href="{{ gUrl }}"
                                    class="sidebar-link flex items-center gap-2 px-3 py-1.5 text-sm {% if activeGenres and genre.id in activeGenres %}active text-white{% else %}text-slate-500{% endif %} rounded-lg transition-all duration-200">
                                    {{ genre.name }}
                                </a>
                            {% endfor %}
                        {% else %}
                            <span class="px-3 py-1 text-xs text-text-muted">Loading...</span>
                        {% endif %}
                    </div>
                </div>

            </nav>
        </aside>

        <!-- MOBILE SIDEBAR -->
        <div id="mobile-sidebar"
            class="fixed inset-y-0 left-0 w-72 bg-dark-bg z-[60] transform -translate-x-full transition-transform duration-300 lg:hidden border-r border-white/[0.05] overflow-y-auto">
            <div class="p-5">
                <div class="flex items-center justify-between mb-6">
                    <a href="/" class="text-xl font-black tracking-wider uppercase">
                        KC <span class="text-primary">CATALOGUE</span>
                    </a>
                    <button onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); document.getElementById('sidebar-overlay').classList.add('hidden')" class="text-white p-1 hover:bg-white/10 rounded-lg">
                        <span class="material-icons">close</span>
                    </button>
                </div>
                <!-- Mobile search -->
                <form action="/search" method="GET" class="relative mb-5">
                    <input type="text" name="q" value="{{ searchQuery or '' }}"
                        class="w-full bg-white/[0.04] text-white rounded-xl py-2.5 pl-10 pr-4 border border-white/[0.06] text-sm"
                        placeholder="Search games...">
                    <span class="material-icons text-text-muted text-lg absolute left-3 top-1/2 -translate-y-1/2">search</span>
                </form>
                <nav class="space-y-4">


                    <h3 class="text-[10px] font-bold text-text-muted px-3 uppercase tracking-[0.15em]">New Releases</h3>
                    <a href="/?tab=last-month" class="block px-3 py-1.5 text-sm text-slate-400 hover:text-white">Last 30 days</a>
                    <a href="/?tab=this-year" class="block px-3 py-1.5 text-sm text-slate-400 hover:text-white">This year</a>
                    <a href="/calendar" class="block px-3 py-1.5 text-sm text-slate-400 hover:text-white">Release Calendar</a>

                    <h3 class="text-[10px] font-bold text-text-muted px-3 pt-2 uppercase tracking-[0.15em]">Top</h3>
                    <a href="/?tab=best-of-year" class="block px-3 py-1.5 text-sm text-slate-400 hover:text-white">Best of the year</a>
                    <a href="/?tab=popular-2025" class="block px-3 py-1.5 text-sm text-slate-400 hover:text-white">Popular in 2025</a>
                    <a href="/?tab=top-250" class="block px-3 py-1.5 text-sm text-slate-400 hover:text-white">All time top 250</a>

                    <h3 class="text-[10px] font-bold text-text-muted px-3 pt-2 uppercase tracking-[0.15em]">Platforms</h3>
                    {% if platforms %}
                        {% for p in platforms %}
                            {% set pUrl = "/?platforms=" ~ toggleFilter(activePlatforms, p.id) %}
                            {% if activeGenres and activeGenres.length > 0 %}{% set pUrl = pUrl ~ "&genres=" ~ activeGenres|join(',') %}{% endif %}
                            <a href="{{ pUrl }}" class="block px-3 py-1.5 text-sm hover:text-white {% if activePlatforms and p.id in activePlatforms %}text-white font-bold{% else %}text-slate-400{% endif %}">{{ p.name }}</a>
                        {% endfor %}
                    {% endif %}

                    <h3 class="text-[10px] font-bold text-text-muted px-3 pt-2 uppercase tracking-[0.15em] mb-2">Genres</h3>
                    <div class="px-3 mb-3">
                        <div class="relative group">
                            <input type="text" id="genre-search-mobile" placeholder="Filter genres..." 
                                class="w-full bg-white/[0.04] text-white border border-white/10 rounded-xl px-3 py-2 text-sm focus:bg-white/10 focus:border-primary focus:ring-0 transition-all outline-none"
                                onkeyup="filterGenres(this.value, 'genre-list-mobile')">
                            <span class="material-icons text-sm text-text-muted absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none group-focus-within:text-white">search</span>
                        </div>
                    </div>
                    <div id="genre-list-mobile">
                        {% if genres and genres.length > 0 %}
                            {% for genre in genres %}
                                {% set gUrl = "/?genres=" ~ toggleFilter(activeGenres, genre.id) %}
                                {% if activePlatforms and activePlatforms.length > 0 %}{% set gUrl = gUrl ~ "&platforms=" ~ activePlatforms|join(',') %}{% endif %}
                                <a href="{{ gUrl }}" class="flex px-3 py-2 text-sm hover:text-white transition-all duration-200 {% if activeGenres and genre.id in activeGenres %}text-white font-bold{% else %}text-slate-400{% endif %}">{{ genre.name }}</a>
                            {% endfor %}
                        {% endif %}
                    </div>
                </nav>
            </div>
        </div>
        <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[55] hidden lg:hidden" id="sidebar-overlay"
            onclick="document.getElementById('mobile-sidebar').classList.add('-translate-x-full'); this.classList.add('hidden')">
        </div>

        <!-- CONTENT COLUMN -->
        <div class="lg:ml-[240px] flex flex-col min-h-[calc(100vh-72px)]">
            
            <!-- MAIN CONTENT AREA -->
            <main class="flex-1 {% block mainClass %}px-4 lg:px-10 py-8{% endblock %} w-full">
                {% block content %}{% endblock %}
            </main>

            <!-- FOOTER -->
            <footer class="border-t border-white/[0.04] bg-dark-bg mt-auto w-full">
                <div class="px-4 lg:px-10 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8">
                        <div class="flex items-center gap-4">
                            <a href="/" class="text-sm font-black tracking-wider uppercase text-white">KC <span class="text-primary">CATALOGUE</span></a>

                        </div>

                    </div>
                    <div class="flex items-center gap-6 text-xs text-text-muted">
                        <a href="/?tab=top-250" class="hover:text-white transition-colors">Top 250</a>
                        <a href="/?tab=best-of-year" class="hover:text-white transition-colors">Best of 2026</a>
                        <span>&copy; 2026 KC Catalogue</span>
                    </div>
                </div>
            </footer>
        </div>





    <!-- GLOBAL LIGHTBOX -->
    <div id="global-lightbox" class="fixed inset-0 z-[100] bg-black/90 backdrop-blur-sm hidden flex items-center justify-center p-4 lg:p-10 transition-opacity duration-300 opacity-0 cursor-zoom-out" onclick="closeLightbox()">
        <img id="global-lightbox-img" src="" alt="Enlarged view" class="max-w-full max-h-full object-contain rounded-xl shadow-2xl scale-95 transition-transform duration-300 pointer-events-none">
    </div>

    <!-- Dropdown Script -->
    <script>
        function filterGenres(query, listId) {
            const container = document.getElementById(listId);
            const links = container.getElementsByTagName('a');
            const lowerQuery = query.toLowerCase();
            
            for (const link of links) {
                const text = link.textContent.toLowerCase();
                if (text.includes(lowerQuery)) {
                    link.style.display = 'flex';
                } else {
                    link.style.display = 'none';
                }
            }
        }

        function openLightbox(url) {
            const lightbox = document.getElementById('global-lightbox');
            const img = document.getElementById('global-lightbox-img');
            img.src = url;
            lightbox.classList.remove('hidden');
            // small delay for transition trigger
            setTimeout(() => {
                lightbox.classList.remove('opacity-0');
                img.classList.remove('scale-95');
            }, 10);
            document.body.style.overflow = 'hidden'; // prevent background scrolling
        }

        function closeLightbox() {
            const lightbox = document.getElementById('global-lightbox');
            const img = document.getElementById('global-lightbox-img');
            lightbox.classList.add('opacity-0');
            img.classList.add('scale-95');
            setTimeout(() => {
                lightbox.classList.add('hidden');
                img.src = '';
            }, 300); // match transition duration
            document.body.style.overflow = ''; // restore scrolling
        }
        
        function toggleMobileSearch() {
            const bar = document.getElementById('mobile-search-bar');
            if (bar) {
                bar.classList.toggle('hidden');
                if (!bar.classList.contains('hidden')) {
                    bar.querySelector('input').focus();
                }
            }
        }

        function toggleUserDropdown() {
            const dropdown = document.getElementById('user-dropdown');
            if (dropdown) {
                dropdown.classList.toggle('hidden');
                dropdown.classList.toggle('flex');
            }
        }
        window.onclick = function (event) {
            if (!event.target.closest('.group') && !event.target.closest('#user-dropdown') && !event.target.closest('#global-lightbox-img')) {
                const dropdown = document.getElementById('user-dropdown');
                if (dropdown && !dropdown.classList.contains('hidden')) {
                    dropdown.classList.add('hidden');
                    dropdown.classList.remove('flex');
                }
            }
        }
    </script>
