<!DOCTYPE html>
<html class="dark" lang="fr">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login / Sign up — KC Catalogue</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d46f2",
                        "dark-bg": "#151515",
                        "card-bg": "#202020",
                        "text-main": "#ffffff",
                        "text-muted": "#757575",
                    },
                    fontFamily: { "display": ["Space Grotesk", "sans-serif"] },
                },
            },
        }
    </script>
</head>

<body
    class="bg-dark-bg text-text-main font-display antialiased selection:bg-primary selection:text-white flex items-center justify-center min-h-screen relative overflow-hidden">

    <!-- Background Elements -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] bg-purple-600/10 rounded-full blur-[120px]">
        </div>
    </div>

    <!-- Auth Card -->
    <div class="relative z-10 w-full max-w-md p-8">

        <!-- Logo -->
        <div class="text-center mb-10">
            <a href="/"
                class="text-4xl font-black tracking-wider uppercase inline-block hover:scale-105 transition-transform">
                KC<span class="text-primary">CATALOGUE</span>
            </a>
            <p class="text-text-muted mt-2">Join the community. Rate games. Share reviews.</p>
        </div>

        <!-- Error Message -->
        {% if error %}
        <div class="bg-red-500/10 border border-red-500/30 text-red-500 px-4 py-3 rounded-lg mb-6 flex items-center gap-2 text-sm">
            <span class="material-icons text-sm">error</span>
            {{ error }}
        </div>
        {% endif %}

        {% if success %}
        <div class="bg-green-500/10 border border-green-500/30 text-green-500 px-4 py-3 rounded-lg mb-6 flex items-center gap-2 text-sm">
            <span class="material-icons text-sm">check_circle</span>
            {{ success }}
        </div>
        {% endif %}

        <!-- Tabs -->
        <div class="bg-card-bg/50 p-1 rounded-xl flex mb-8 backdrop-blur-sm border border-white/5">
            <button onclick="switchTab('login')" id="tab-login"
                class="flex-1 py-2.5 rounded-lg text-sm font-bold text-white bg-white/10 transition-all shadow-lg">Log
                in</button>
            <button onclick="switchTab('signup')" id="tab-signup"
                class="flex-1 py-2.5 rounded-lg text-sm font-bold text-text-muted hover:text-white transition-all">Sign
                up</button>
        </div>

        <!-- Login Form -->
        <div id="form-login" class="space-y-5">
            <form action="/login" method="POST" class="space-y-5">
                <div class="space-y-4">
                    <input type="email" name="email" placeholder="Email" required
                        class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                    <input type="password" name="password" placeholder="Password" required
                        class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                </div>
                <div class="flex items-center justify-between text-sm">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="checkbox" class="rounded bg-card-bg border-white/10 text-primary focus:ring-0">
                        <span class="text-text-muted group-hover:text-white transition-colors">Remember me</span>
                    </label>
                    <a href="#" class="text-text-muted hover:text-white transition-colors">Forgot password?</a>
                </div>
                <button type="submit"
                    class="w-full bg-white text-black hover:bg-primary hover:text-white py-3.5 rounded-lg font-bold text-lg transition-all transform hover:scale-[1.02]">
                    Log in
                </button>
            </form>
        </div>

        <!-- Signup Form -->
        <div id="form-signup" class="space-y-5 hidden">
            <form action="/register" method="POST" class="space-y-5">
                <div class="space-y-4">
                    <input type="text" name="username" placeholder="Username" required
                        class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                    <input type="email" name="email" placeholder="Email" required
                        class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                    <input type="password" name="password" placeholder="Password" required
                        class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                </div>
                <div class="text-xs text-text-muted leading-relaxed">
                    By clicking "Create Account", you agree to our <a href="#" class="text-white hover:underline">Terms of
                        Service</a> and <a href="#" class="text-white hover:underline">Privacy Policy</a>.
                </div>
                <button type="submit"
                    class="w-full bg-primary text-white hover:bg-primary/90 py-3.5 rounded-lg font-bold text-lg transition-all transform hover:scale-[1.02] shadow-[0_0_20px_rgba(13,70,242,0.3)]">
                    Create Account
                </button>
            </form>
        </div>

        <!-- Social Login -->
        <div class="mt-8 pt-8 border-t border-white/10">
            <p class="text-center text-xs font-bold uppercase tracking-widest text-text-muted mb-6">Or continue with</p>
            <div class="grid grid-cols-1 gap-3">
                <a href="/auth/steam"
                    class="bg-card-bg hover:bg-white/10 border border-white/5 rounded-lg p-3 flex items-center justify-center transition-all group">
                    <img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/steam.svg"
                        class="w-5 h-5 opacity-70 group-hover:opacity-100 transition-opacity" style="filter: brightness(0) invert(1);" alt="Steam">
                </a>
            </div>
        </div>

    </div>

    <script>
        function switchTab(tab) {
            const loginForm = document.getElementById('form-login');
            const signupForm = document.getElementById('form-signup');
            const loginTab = document.getElementById('tab-login');
            const signupTab = document.getElementById('tab-signup');

            if (tab === 'login') {
                loginForm.classList.remove('hidden');
                signupForm.classList.add('hidden');
                loginTab.classList.add('bg-white/10', 'text-white', 'shadow-lg');
                loginTab.classList.remove('text-text-muted');
                signupTab.classList.remove('bg-white/10', 'text-white', 'shadow-lg');
                signupTab.classList.add('text-text-muted');
            } else {
                loginForm.classList.add('hidden');
                signupForm.classList.remove('hidden');
                signupTab.classList.add('bg-white/10', 'text-white', 'shadow-lg');
                signupTab.classList.remove('text-text-muted');
                loginTab.classList.remove('bg-white/10', 'text-white', 'shadow-lg');
                loginTab.classList.add('text-text-muted');
            }
        }

        {% if mode == 'register' %}
            switchTab('signup');
        {% endif %}
    </script>
</body>

</html>
