<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Reset Password — KC Catalogue</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d46f2",
                        "dark-bg": "#151515",
                        "card-bg": "#202020",
                        "text-main": "#ffffff",
                        "text-muted": "#757575",
                    },
                    fontFamily: { "display": ["Space Grotesk", "sans-serif"] },
                },
            },
        }
    </script>
</head>
<body class="bg-dark-bg text-text-main font-display antialiased flex items-center justify-center min-h-screen relative overflow-hidden">
    <div class="absolute inset-0 z-0">
        <div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] bg-primary/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative z-10 w-full max-w-md p-8">
        <div class="text-center mb-10">
            <a href="/" class="text-4xl font-black tracking-wider uppercase inline-block">
                KC<span class="text-primary">CATALOGUE</span>
            </a>
            <h1 class="text-xl font-bold mt-6">Set new password</h1>
            <p class="text-text-muted mt-2">Please enter your new password below.</p>
        </div>

        {% if error %}
        <div class="bg-red-500/10 border border-red-500/30 text-red-500 px-4 py-3 rounded-lg mb-6 flex items-center gap-2 text-sm">
            <span class="material-icons text-sm">error</span>
            {{ error }}
        </div>
        {% endif %}

        <form action="/reset-password/{{ token }}" method="POST" class="space-y-4">
            <div class="space-y-4">
                <input type="password" name="password" placeholder="New password" required
                    class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                <input type="password" name="confirm_password" placeholder="Confirm new password" required
                    class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
            </div>
            
            <button type="submit"
                class="w-full bg-primary text-white hover:bg-primary/90 py-3.5 rounded-lg font-bold text-lg transition-all transform hover:scale-[1.02] shadow-[0_0_20px_rgba(13,70,242,0.3)]">
                Reset Password
            </button>
        </form>
    </div>
</body>
</html>
