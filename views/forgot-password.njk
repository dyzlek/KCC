<!DOCTYPE html>
<html class="dark" lang="fr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Forgot Password — KC Catalogue</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d46f2",
                        "dark-bg": "#151515",
                        "card-bg": "#202020",
                        "text-main": "#ffffff",
                        "text-muted": "#757575",
                    },
                    fontFamily: { "display": ["Space Grotesk", "sans-serif"] },
                },
            },
        }
    </script>
</head>
<body class="bg-dark-bg text-text-main font-display antialiased flex items-center justify-center min-h-screen relative overflow-hidden">
    <div class="absolute inset-0 z-0">
        <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] bg-primary/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative z-10 w-full max-w-md p-8">
        <div class="text-center mb-10">
            <a href="/" class="text-4xl font-black tracking-wider uppercase inline-block">
                KC<span class="text-primary">CATALOGUE</span>
            </a>
            <h1 class="text-xl font-bold mt-6">Forgot your password?</h1>
            <p class="text-text-muted mt-2">Enter your email address and we'll send you a link to reset your password.</p>
        </div>

        {% if error %}
        <div class="bg-red-500/10 border border-red-500/30 text-red-500 px-4 py-3 rounded-lg mb-6 flex items-center gap-2 text-sm">
            <span class="material-icons text-sm">error</span>
            {{ error }}
        </div>
        {% endif %}

        {% if success %}
        <div class="bg-green-500/10 border border-green-500/30 text-green-500 px-4 py-3 rounded-lg mb-6 flex items-center gap-2 text-sm">
            <span class="material-icons text-sm">check_circle</span>
            {{ success }}
        </div>
        {% endif %}

        <form action="/forgot-password" method="POST" class="space-y-6">
            <input type="email" name="email" placeholder="Your email address" required
                class="w-full bg-card-bg border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-text-muted focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
            
            <button type="submit"
                class="w-full bg-white text-black hover:bg-primary hover:text-white py-3.5 rounded-lg font-bold text-lg transition-all transform hover:scale-[1.02]">
                Send Reset Link
            </button>
        </form>

        <div class="mt-8 text-center">
            <a href="/login" class="text-sm text-text-muted hover:text-white transition-colors flex items-center justify-center gap-2">
                <span class="material-icons text-sm">arrow_back</span> Back to login
            </a>
        </div>
    </div>
</body>
</html>
