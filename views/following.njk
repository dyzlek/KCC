{% extends "layout.njk" %}

{% block content %}

<!-- HEADER -->
<div class="mb-8">
    <div class="flex items-center gap-4 mb-2">
        <a href="/profile/{{ profileUser.id }}" class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/20 to-purple-600/20 border border-white/10 flex items-center justify-center overflow-hidden hover:scale-105 transition-transform">
            {% if profileUser.avatar_url %}
                <img src="{{ profileUser.avatar_url }}" alt="{{ profileUser.username }}" class="w-full h-full object-cover">
            {% else %}
                <span class="text-primary font-black text-xl">{{ profileUser.username[0] | upper }}</span>
            {% endif %}
        </a>
        <div>
            <h1 class="text-3xl font-black text-white">
                <a href="/profile/{{ profileUser.id }}" class="hover:text-primary transition-colors">{{ profileUser.username }}</a>
                <span class="text-text-muted text-lg font-normal ml-1">/ Following</span>
            </h1>
            <div class="flex items-center gap-4 text-sm text-text-muted">
                <span><strong class="text-white">{{ followCounts.followers }}</strong> followers</span>
                <span><strong class="text-white">{{ followCounts.following }}</strong> following</span>
            </div>
        </div>
    </div>
</div>

{% if followsPrivate %}
    <!-- Privacy Message -->
    <div class="bg-card-bg/40 rounded-2xl p-12 text-center border border-white/5">
        <span class="material-icons text-5xl text-white/10 mb-4 block">lock</span>
        <p class="text-text-muted font-bold text-lg mb-2">This list is private</p>
        <p class="text-text-muted text-sm">{{ profileUser.username }} has chosen to keep their following list private.</p>
    </div>
{% elif followingList and followingList.length > 0 %}
    <!-- Following List -->
    <div class="space-y-3">
        {% for person in followingList %}
        <div class="bg-card-bg/40 rounded-xl p-4 border border-white/5 hover:border-primary/20 transition-all flex items-center justify-between group">
            <a href="/profile/{{ person.id }}" class="flex items-center gap-4 flex-1 min-w-0">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/20 to-purple-600/20 border border-white/10 flex items-center justify-center overflow-hidden flex-shrink-0 group-hover:scale-105 transition-transform">
                    {% if person.avatar_url %}
                        <img src="{{ person.avatar_url }}" alt="{{ person.username }}" class="w-full h-full object-cover">
                    {% else %}
                        <span class="text-primary font-black text-lg">{{ person.username[0] | upper }}</span>
                    {% endif %}
                </div>
                <div class="min-w-0">
                    <h3 class="font-bold text-white text-sm group-hover:text-primary transition-colors truncate">{{ person.username }}</h3>
                    {% if person.bio %}
                        <p class="text-text-muted text-xs truncate max-w-md">{{ person.bio }}</p>
                    {% endif %}
                    <span class="text-[10px] text-text-muted opacity-60">Followed {{ person.followed_at | timeAgo }}</span>
                </div>
            </a>

            {% if isOwnProfile %}
                <button onclick="unfollowUser({{ person.id }}, this)" 
                    class="ml-4 bg-card-bg hover:bg-red-500/10 text-white border border-white/10 px-4 py-2 rounded-lg font-bold text-xs transition-all flex items-center gap-2 flex-shrink-0 group/btn">
                    <span class="material-icons text-sm text-text-muted group-hover/btn:text-red-400">person_remove</span>
                    <span class="group-hover/btn:hidden">Following</span>
                    <span class="hidden group-hover/btn:inline text-red-400">Unfollow</span>
                </button>
            {% endif %}
        </div>
        {% endfor %}
    </div>
{% else %}
    <!-- Empty State -->
    <div class="bg-card-bg/40 rounded-2xl p-12 text-center border border-white/5">
        <span class="material-icons text-5xl text-white/10 mb-4 block">person_search</span>
        {% if isOwnProfile %}
            <p class="text-text-muted font-bold text-lg mb-2">You're not following anyone yet</p>
            <p class="text-text-muted text-sm mb-4">Explore profiles and start following people to build your feed!</p>
            <a href="/" class="text-primary text-sm font-bold hover:underline">Browse games</a>
        {% else %}
            <p class="text-text-muted font-bold text-lg mb-2">{{ profileUser.username }} isn't following anyone yet</p>
        {% endif %}
    </div>
{% endif %}

{% if isOwnProfile %}
<script>
async function unfollowUser(userId, btn) {
    if (!confirm('Are you sure you want to unfollow this user?')) return;
    try {
        const res = await fetch('/follow/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ targetUserId: userId })
        });
        const data = await res.json();
        if (data.success) {
            // Remove the card with animation
            const card = btn.closest('.space-y-3 > div');
            card.style.transition = 'opacity 0.3s, transform 0.3s';
            card.style.opacity = '0';
            card.style.transform = 'translateX(20px)';
            setTimeout(() => card.remove(), 300);
        }
    } catch (err) {
        console.error('Error unfollowing:', err);
    }
}
</script>
{% endif %}

{% endblock %}
